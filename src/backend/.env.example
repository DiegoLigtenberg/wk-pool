# Comma-separated frontend origins that may call the backend.
WK_POOL_ALLOWED_ORIGINS=https://wk-pool.up.railway.app,http://localhost:5173,http://127.0.0.1:5173

# API-Sports / API-Football key (https://www.api-football.com/documentation-v3)
FOOTBALL_API_KEY=
# Season year for sync (2026 during the tournament; use 2022 on free plan for testing)
FOOTBALL_API_SEASON=2026

# Railway sets PORT automatically. HOST is optional and only needed outside Railway.
# HOST=0.0.0.0
# PORT=8000

# --- Backend (local dev + Railway wk-pool-backend) ---

# Comma-separated frontend origins that may call the backend.
WK_POOL_ALLOWED_ORIGINS=https://wk-pool.up.railway.app,http://localhost:5173,http://127.0.0.1:5173

# Results provider: espn (default, free, no key) or api-football (paid for 2026)
FOOTBALL_DATA_PROVIDER=espn

# API-Sports / API-Football key — only when FOOTBALL_DATA_PROVIDER=api-football
FOOTBALL_API_KEY=
# Season year for API-Football sync (2026 during the tournament; use 2022 on free plan for testing)
FOOTBALL_API_SEASON=2026

# Secret for POST /internal/sync-football (required on backend in production)
FOOTBALL_SYNC_SECRET=secret-key-here

# Railway backend only: persistent volume mount at /data (omit locally — uses src/backend/app/data/)
# WK_POOL_DATA_DIR=/data

# Railway sets PORT automatically. HOST is optional and only needed outside Railway.
# HOST=0.0.0.0
# PORT=8000

# --- Cron trigger service only (wk-pool-cron-sync; unexposed, no public domain) ---

# BACKEND_URL=https://your-backend.up.railway.app
# FOOTBALL_SYNC_SECRET=same-as-backend

# --- Manual sync from your machine ---

# Direct (writes local data dir):
#   cd src/backend && poetry run python scripts/sync_football_results.py --force-remap
#
# Via Railway backend (writes backend volume):
#   cd src/backend
#   set BACKEND_URL=https://your-backend.up.railway.app
#   set FOOTBALL_SYNC_SECRET=...
#   poetry run python scripts/trigger_football_sync.py --force-remap
